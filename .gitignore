cat > .gitignore <<'EOF'
# Python
__pycache__/
*.py[cod]
*.so

# Virtualenv
venv/
.venv/

# Secrets / env
.env
.env.local

# Local config
config/participants.json

# Runtime / memory
memory/
*.jsonl
*.log

# Editors / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Build / test
build/
dist/
*.egg-info/
.pytest_cache/
.coverage
htmlcov/

# Optional frontend
node_modules/
EOF
